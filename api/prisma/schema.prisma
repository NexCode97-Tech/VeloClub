generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Club ────────────────────────────────────────────────────────────────────

model Club {
  id                String          @id @default(cuid())
  name              String
  city              String?
  department        String?
  logoUrl           String?
  logoPublicId      String?
  coverUrl          String?         // portada del club
  coverPublicId     String?         // public_id de Cloudinary
  verified          Boolean         @default(false)  // club verificado
  active            Boolean         @default(true)
  trialEndsAt       DateTime?
  deporte           String?
  description       String?
  noAttendanceDays  Int[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  users          User[]
  locations      Location[]
  members        Member[]
  payments       Payment[]
  cashEntries    CashEntry[]
  competitions      Competition[]
  trainingSessions  TrainingSession[]
  calendarEvents    CalendarEvent[]
  attendances    Attendance[]
  suscripcion    ClubSuscripcion?
  posts          Post[]
}

// ─── User (staff: ADMIN, COACH, SUPERADMIN) ──────────────────────────────────

model User {
  id              String   @id @default(cuid())
  clerkId         String   @unique
  email           String   @unique
  name            String
  picture         String?
  coverUrl        String?
  coverPublicId   String?
  role            Role     @default(ADMIN)
  profileComplete Boolean  @default(false)
  clubId          String?
  club            Club?    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([clubId])
}

// ─── Location (sedes) ────────────────────────────────────────────────────────

model Location {
  id             String           @id @default(cuid())
  name           String
  address        String?
  latitude       Float?
  longitude      Float?
  clubId         String
  club           Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  members          MemberLocation[]
  attendances      Attendance[]
  trainingSessions TrainingSession[]
  calendarEvents   CalendarEvent[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([clubId])
}

// ─── Member (deportistas) ────────────────────────────────────────────────────

model Member {
  id                String           @id @default(cuid())
  clubId            String
  club              Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  fullName          String
  email             String?
  phone             String?
  birthDate         DateTime?
  pictureUrl        String?
  picturePublicId   String?
  docType           String?
  docNumber         String?
  docFileUrl        String?
  docFilePublicId   String?
  insuranceFileUrl  String?
  insurancePublicId String?
  emergencyContact  String?
  emergencyPhone    String?
  eps               String?
  category          String?
  tipo              String?
  paymentDueDay     Int?
  monthlyFee        Float?
  locations         MemberLocation[]
  attendances       Attendance[]
  payments          Payment[]
  eventResults      EventResult[]
  trainingResults   TrainingResult[]
  inviteStatus      InviteStatus     @default(PENDING)
  clerkId           String?          @unique
  role              Role             @default(STUDENT)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([clubId])
  @@index([email])
}

model MemberLocation {
  memberId   String
  locationId String
  member     Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([memberId, locationId])
}

// ─── Attendance (asistencia) ─────────────────────────────────────────────────

model Attendance {
  id         String           @id @default(cuid())
  clubId     String
  club       Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  memberId   String
  member     Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  locationId String?
  location   Location?        @relation(fields: [locationId], references: [id])
  date       DateTime         @db.Date
  status     AttendanceStatus
  notes      String?
  createdAt  DateTime         @default(now())

  @@unique([memberId, date])
  @@index([clubId, date])
  @@index([memberId])
}

// ─── Payment (pagos de mensualidad) ──────────────────────────────────────────

model Payment {
  id        String        @id @default(cuid())
  clubId    String
  club      Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  memberId  String
  member    Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  amount    Float
  month     Int
  year      Int
  dueDate   DateTime?
  paidAt    DateTime?
  status    PaymentStatus @default(PENDING)
  notes           String?
  receiptUrl      String?
  receiptPublicId String?
  cashEntry       CashEntry?
  createdAt       DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([clubId])
  @@index([memberId])
  @@index([clubId, year, month])
}

// ─── CashEntry (flujo de caja) ───────────────────────────────────────────────

model CashEntry {
  id          String        @id @default(cuid())
  clubId      String
  club        Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  type        CashEntryType
  amount      Float
  description String
  date        DateTime      @default(now())
  paymentId   String?       @unique
  payment     Payment?      @relation(fields: [paymentId], references: [id])
  createdAt   DateTime      @default(now())

  @@index([clubId])
  @@index([clubId, date])
}

// ─── Competition + Events + Results (logros) ─────────────────────────────────

model Competition {
  id        String             @id @default(cuid())
  clubId    String
  club      Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name      String
  place     String?
  date      DateTime
  events    CompetitionEvent[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([clubId])
}

model CompetitionEvent {
  id            String        @id @default(cuid())
  competitionId String
  competition   Competition   @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  name          String
  results       EventResult[]
  createdAt     DateTime      @default(now())
}

model EventResult {
  id           String           @id @default(cuid())
  eventId      String
  event        CompetitionEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  memberId     String
  member       Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  position     Int?
  category     String?
  observations String?
  createdAt    DateTime         @default(now())

  @@unique([eventId, memberId])
  @@index([memberId])
}

// ─── TrainingSession + Results (entrenamientos) ──────────────────────────────

model TrainingSession {
  id         String           @id @default(cuid())
  clubId     String
  club       Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  title      String
  date       DateTime
  locationId String?
  location   Location?        @relation(fields: [locationId], references: [id])
  notes      String?
  results    TrainingResult[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([clubId])
  @@index([clubId, date])
}

model TrainingResult {
  id          String          @id @default(cuid())
  sessionId   String
  session     TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  memberId    String
  member      Member          @relation(fields: [memberId], references: [id], onDelete: Cascade)
  time        String?
  distance    String?
  laps        Int?
  observations String?
  createdAt   DateTime        @default(now())

  @@unique([sessionId, memberId])
  @@index([memberId])
}

// ─── CalendarEvent (calendario) ──────────────────────────────────────────────

model CalendarEvent {
  id          String            @id @default(cuid())
  clubId      String
  club        Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  title       String
  type        CalendarEventType
  description String?
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean           @default(true)
  recurrence  RecurrenceType    @default(NONE)
  weekDays    Int[]
  locationId  String?
  location    Location?         @relation(fields: [locationId], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([clubId])
  @@index([clubId, startDate])
}

// ─── ClubSuscripcion (cobros de plataforma por club) ─────────────────────────

model ClubSuscripcion {
  id        String              @id @default(cuid())
  clubId    String              @unique
  club      Club                @relation(fields: [clubId], references: [id], onDelete: Cascade)
  planMonto Float               @default(450000)
  tipoPlan  TipoPlan            @default(MENSUAL)
  año       Int
  pagos     SuscripcionPago[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([clubId])
}

model SuscripcionPago {
  id              String          @id @default(cuid())
  suscripcionId   String
  suscripcion     ClubSuscripcion @relation(fields: [suscripcionId], references: [id], onDelete: Cascade)
  concepto        String
  monto           Float
  fecha           DateTime?
  estado          PaymentStatus   @default(PENDING)
  receiptUrl      String?
  receiptPublicId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([suscripcionId])
}

// ─── Post (feed comunitario) ─────────────────────────────────────────────────

model Post {
  id              String     @id @default(cuid())
  clubId          String
  club            Club       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  clubName        String     @default("")
  authorName      String
  authorRole      String
  authorAvatar    String?
  content         String
  imageUrl        String?
  imagePublicId   String?
  scope           PostScope  @default(PRIVATE)
  likes           PostLike[]
  comments        PostComment[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([clubId])
  @@index([scope, createdAt])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

model PostComment {
  id          String   @id @default(cuid())
  postId      String
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorName  String
  authorRole  String
  authorAvatar String?
  content     String
  createdAt   DateTime @default(now())

  @@index([postId])
  @@index([postId, createdAt])
}

// ─── Notificacion (SA global) ─────────────────────────────────────────────────

model Notificacion {
  id        String           @id @default(cuid())
  tipo      NotificacionTipo
  titulo    String
  cuerpo    String
  leida     Boolean          @default(false)
  createdAt DateTime         @default(now())
}

// ─── Follow (sistema de seguidores) ─────────────────────────────────────────

model Follow {
  id               String   @id @default(cuid())
  followerClerkId  String
  followingClerkId String
  createdAt        DateTime @default(now())

  @@unique([followerClerkId, followingClerkId])
  @@index([followerClerkId])
  @@index([followingClerkId])
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  SUPERADMIN
  ADMIN
  COACH
  STUDENT
}

enum InviteStatus {
  PENDING
  ACCEPTED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  MEDICAL_EXCUSE
  LATE
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  REFUNDED
}

enum CashEntryType {
  INCOME
  EXPENSE
  REFUND
}

enum CalendarEventType {
  TRAINING
  MEETUP
  COMPETITION
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  CUSTOM
}

enum NotificacionTipo {
  CLUB_CREADO
  CLUB_DESACTIVADO
  PAGO_VENCIDO
  PAGO_REGISTRADO
}

enum TipoPlan {
  MENSUAL
  TRIMESTRAL
  ANUAL
}

enum PostScope {
  PUBLIC
  PRIVATE
}
